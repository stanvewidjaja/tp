@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nReadOnlyShortcutMap" as ReadOnlyShortcutMap
Class "<<interface>>\nModel" as Model
Class AddressBook
Class ModelManager
Class UserPrefs
Class ShortcutMap

Class UniqueLocationList

Class Location
Class Address
Class Email
Class Name
Class Phone
Class PostalCode
Class Tag
Class VisitDate
Class NoteContent

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook
UserPrefs .up.|> ReadOnlyUserPrefs
ShortcutMap .up.|> ReadOnlyShortcutMap

ModelManager .up.|> Model
Model .left.> ReadOnlyAddressBook
Model .right.> ReadOnlyUserPrefs
Model .down.> ReadOnlyShortcutMap

ModelManager -left-> "1" AddressBook
ModelManager -right-> "1" UserPrefs
ModelManager -down-> "1" ShortcutMap

AddressBook *--> "1" UniqueLocationList
UniqueLocationList --> "~* all" Location
ModelManager --> "~* filtered" Location

Location *--> Name
Location *--> "0..1" Phone
Location *--> "0..1" Email
Location *--> "0..1" Address
Location *--> "0..1" PostalCode
Location *--> "*" Tag
Location *--> "*" VisitDate

VisitDate --> "0..1" NoteContent

Location -[hidden]up--> I
UniqueLocationList -[hidden]right-> I

Name -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email
Email -[hidden]right-> PostalCode

@enduml
