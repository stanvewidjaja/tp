<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <GridPane HBox.hgrow="ALWAYS">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150" />
    </columnConstraints>
    <VBox alignment="CENTER_LEFT" minHeight="105" GridPane.columnIndex="0" HBox.hgrow="ALWAYS">
      <padding>
        <Insets top="10" right="5" bottom="10" left="15" />
      </padding>
      <HBox spacing="0.5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
        <Label fx:id="id" styleClass="cell_big_label">
          <minWidth>
            <!-- Ensures that the label text is never truncated -->
            <Region fx:constant="USE_PREF_SIZE" />
          </minWidth>
        </Label>
        <Label fx:id="name" text="\$first" styleClass="cell_big_label" />
      </HBox>
      <FlowPane fx:id="tags" />
      <Label fx:id="address" styleClass="cell_small_label" text="\$address" />
      <Label fx:id="postalCode" styleClass="cell_small_label" text="$postalCode" />
      <HBox spacing="10" minWidth="200">
        <Label fx:id="phone" styleClass="cell_small_label" text="\$phone" HBox.hgrow="ALWAYS"/>
        <Label fx:id="email" styleClass="cell_small_label" text="\$email" HBox.hgrow="ALWAYS"/>
      </HBox>
      <FlowPane fx:id="visitDates" />
      <!-- <Label fx:id="visitDate" styleClass="cell_small_label" text="\$visitDate " /> -->
    </VBox>
  </GridPane>
</HBox>
